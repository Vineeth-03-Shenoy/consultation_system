    <bpmn:textAnnotation id="Text_CWSvrA">
      <bpmn:text>Move the Booking mail to subfolder "Processed"</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="Text_rPeIMx">
      <bpmn:text>Agent creates a Time Slot in the Doctor Schedule based on the Patient history and probable priority</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="Text_f6HIx6">
      <bpmn:text> Gets Patient, Doctor, Appointment, and Schedule Records from Data Fabric</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="Text_rEp8OC">
      <bpmn:text>Sends a Confirmation Mail to the patient </bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="Text_5EayD2">
      <bpmn:text>Wait for Appointment Day or a Reschedule Mail</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="Text_iEIcAu">
      <bpmn:text>Catch the Email Sent as a Reschedule Request to the Patient</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="Text_q7N9Ff">
      <bpmn:text>Wait for Patient's Response for 8 hours.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="Text_MDf07U">
      <bpmn:text>Patient's Response Received to the Reschedule Request</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="Text_LRaOwA">
      <bpmn:text>Catch the Reschedule/Cancel mail sent by the bot on Patient's Request before the day of Appointment</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="Text_uADp0k">
      <bpmn:text>Update the Appointment Status to "Cancelled" due to No response from Patient </bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="Text_Sg0BX9">
      <bpmn:text>Analyse the Patient's Reply using Generative AI and identify the Option selected</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="Text_7IR6oQ">
      <bpmn:text>Moves Mail from RescheduleByDoctorsRequest to Processed</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="Text_CTl3OT">
      <bpmn:text>Sends the Booking Mail to Trigger a Separate Instance</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="Text_GdbH8H">
      <bpmn:text>Catches the Final Reminder sent to the patient on the Day of the Appointment</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="Text_9iHk48">
      <bpmn:text>Check-In Action App waits for Receptionist to Check-in the patient, take the reason for visit and submit any test report</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="Text_yYzX2M">
      <bpmn:text>Consultation Action App that provides Helpful and relevant data for the Doctor. It takes in the Doctor Notes. Optionally Takes Tests suggested and Prescribed Meds.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="Text_hcsmUn">
      <bpmn:text>Updates the Appointment Status to Completed along with EndTime</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="Text_ROj6GW">
      <bpmn:text>Creates an Action App task for the Lab Receptionist to initiate, process and Submit Tests suggested by the Doctor</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="Text_joen3u">
      <bpmn:text>Creates an Action App task for the Pharmacist to initiate, pack and bill the medicines prescribed by the Doctor</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="Text_qOD9Jw">
      <bpmn:text>BPMN logic does not allow Intermediate trigger to be connected to an Event Gateway.</bpmn:text>
    </bpmn:textAnnotation>
  </bpmn:process>
