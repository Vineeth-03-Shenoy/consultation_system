        }
      ],
      "checkEmerg": [
        {
          "variableId": "emergencyOccurred",
          "expression": "=js:($vars.checkEmerg.output || {}).occurred === true"
        }
      ],
      "checkReply2": [
        {
          "variableId": "reply2Received",
          "expression": "=js:($vars.checkReply2.output || {}).received === true"
        }
      ]
