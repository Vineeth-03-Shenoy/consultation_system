  "subflows": {
    "dayOfConsult": {
      "nodes": [
        {
          "id": "dcStart",
          "type": "core.trigger.manual",
          "typeVersion": "1.0",
          "display": {
            "label": "Start"
          },
          "inputs": {
            "entryPointId": "5f1c2b7e-9a44-4d7c-8b2e-3d6a1f0c9e21",
            "isDefaultEntryPoint": true
          },
          "outputs": {
            "output": {
              "type": "object",
              "description": "Data passed when manually triggering the workflow.",
              "source": "null",
              "var": "output"
            }
          }
        },
        {
          "id": "checkInTask",
          "type": "core.logic.mock",
          "typeVersion": "1.0",
          "display": {
            "label": "Check In Action App (mock HITL)"
          },
          "inputs": {},
          "outputs": {
            "output": {
              "type": "object",
              "description": "Mock output value",
              "source": "null",
              "var": "output"
            }
          }
        },
        {
          "id": "routeCheckin",
          "type": "core.logic.switch",
          "typeVersion": "1.1",
          "display": {
            "label": "Check-in?"
          },
          "inputs": {
            "cases": [
              {
                "id": "checkedIn",
                "label": "Checked in",
                "expression": "(($vars.checkInTask.output || {status: \"checkedIn\"}).status) === \"checkedIn\""
              },
              {
                "id": "timedOut",
                "label": "24h timeout",
                "expression": "(($vars.checkInTask.output || {}).status) === \"timedOut\""
              }
            ]
          }
        },
        {
          "id": "updCheckedin",
          "type": "core.logic.mock",
