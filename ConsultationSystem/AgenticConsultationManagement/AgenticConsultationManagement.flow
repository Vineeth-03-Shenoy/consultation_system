        "isDefaultEntryPoint": true
      },
      "outputs": {
        "output": {
          "type": "object",
          "description": "Data passed when manually triggering the workflow.",
          "source": "null",
          "var": "output"
        }
      }
    },
    {
      "id": "moveTriggerMail",
      "type": "core.logic.mock",
      "typeVersion": "1.0",
