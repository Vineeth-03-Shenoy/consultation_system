            },
            "testsNeeded": {
              "source": "=js:(($vars.doctorNotes.output || {}).testsNeeded) === true"
            },
            "medsNeeded": {
              "source": "=js:(($vars.doctorNotes.output || {}).medsNeeded) === true"
            }
          }
