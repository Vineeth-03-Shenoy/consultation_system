              },
              "category": {
                "type": "string",
                "description": "Error category",
                "descriptionKey": "subflowInterface_errorCategory_description"
              },
              "status": {
                "type": "integer",
                "description": "HTTP status code",
                "descriptionKey": "subflowInterface_errorStatus_description"
              }
            },
            "additionalProperties": false
          }
        },
        "output": {
          "type": "object",
          "description": "The return value of the subflow",
          "source": "=result.response",
          "var": "output",
          "properties": {
            "outcome": {
