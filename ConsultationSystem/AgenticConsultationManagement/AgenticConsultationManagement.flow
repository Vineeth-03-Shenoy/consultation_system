    {
      "id": "pollDayLoop",
      "type": "core.logic.loop",
      "typeVersion": "2.4",
      "display": {
        "label": "Wait for Appointment Day (poll)"
      },
      "inputs": {
        "collection": "=js:Array.from({length: 20}, (_, i) => i + 1)",
        "parallel": false,
        "completionCondition": "$vars.dayEventType !== \"\""
      },
      "outputs": {
        "currentItem": {
          "type": "any",
          "description": "The current item being iterated in the loop",
          "scope": "internal",
          "source": "=loopContext.currentItem",
          "var": "currentItem"
        },
        "currentIteration": {
          "type": "number",
          "description": "The current iteration number (1-based)",
          "scope": "internal",
          "source": "=loopContext.currentIteration",
          "var": "currentIteration"
        },
        "collection": {
          "type": "array",
          "description": "The collection being iterated over",
          "scope": "internal",
          "source": "=loopContext.collection",
          "var": "collection"
        },
        "output": {
          "type": "array",
          "description": "Aggregated results from all loop iterations",
          "scope": "external",
          "source": "=loopContext.output",
          "var": "output"
        },
        "error": {
          "type": "object",
          "description": "Error information if the node fails",
          "schema": {
            "$schema": "http://json-schema.org/draft-07/schema#",
            "type": "object",
            "required": [
              "code",
              "message",
              "detail",
              "category",
              "status"
            ],
            "properties": {
              "code": {
                "type": "string",
                "description": "Error code as a string"
              },
              "message": {
                "type": "string",
                "description": "High-level error message"
              },
              "detail": {
                "type": "string",
                "description": "Detailed error description"
              },
              "category": {
                "type": "string",
                "description": "Error category"
              },
              "status": {
                "type": "integer",
                "description": "HTTP status code"
              }
            },
            "additionalProperties": false
          },
          "source": "=Error",
          "var": "error"
        }
      }
    },
    {
      "id": "delayDayPoll",
      "type": "core.logic.delay",
      "typeVersion": "1.0",
      "display": {
        "label": "Poll interval"
      },
      "inputs": {
        "timerType": "timeDuration",
        "timerPreset": "PT5S"
      },
      "parentId": "pollDayLoop"
    },
    {
      "id": "checkDayEvents",
      "type": "core.action.script",
      "typeVersion": "1.0",
      "display": {
        "label": "Check for events (mock)"
      },
      "inputs": {
        "script": "// Mock: in production this checks the mailbox / Data Fabric for doctorEmergency, rescheduleCancel or finalReminder events\nreturn { eventType: \"finalReminder\" };"
      },
      "outputs": {
        "output": {
          "type": "object",
          "description": "The return value of the script",
          "source": "=result.response",
          "var": "output"
        },
        "error": {
          "type": "object",
          "description": "Error information if the script fails",
          "source": "=Error",
          "var": "error"
        }
      },
      "parentId": "pollDayLoop"
    },
    {
      "id": "routeDayEvent",
      "type": "core.logic.switch",
      "typeVersion": "1.1",
      "display": {
        "label": "Which Event"
      },
      "inputs": {
        "cases": [
          {
            "id": "doctorEmergency",
            "label": "Doctor Emergency",
            "expression": "$vars.dayEventType === \"doctorEmergency\""
          },
          {
            "id": "rescheduleCancel",
            "label": "Reschedule or Cancel",
            "expression": "$vars.dayEventType === \"rescheduleCancel\""
          },
          {
            "id": "finalReminder",
            "label": "Final Reminder",
            "expression": "$vars.dayEventType === \"finalReminder\""
          }
        ]
      }
    },
    {
      "id": "pollReplyLoop1",
      "type": "core.logic.loop",
      "typeVersion": "2.4",
      "display": {
        "label": "Wait for Patient Reply (8h poll)"
      },
      "inputs": {
        "collection": "=js:Array.from({length: 20}, (_, i) => i + 1)",
        "parallel": false,
        "completionCondition": "$vars.reply1Received === true"
      },
      "outputs": {
        "currentItem": {
          "type": "any",
          "description": "The current item being iterated in the loop",
          "scope": "internal",
          "source": "=loopContext.currentItem",
          "var": "currentItem"
        },
        "currentIteration": {
          "type": "number",
          "description": "The current iteration number (1-based)",
          "scope": "internal",
          "source": "=loopContext.currentIteration",
