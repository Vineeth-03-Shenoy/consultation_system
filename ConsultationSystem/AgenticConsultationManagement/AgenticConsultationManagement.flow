    {
      "id": "outcomeOk",
      "type": "core.logic.decision",
      "typeVersion": "1.1",
      "display": {
        "label": "Consultation Completed?"
      },
      "inputs": {
        "expression": "(($vars.dayOfConsult.output || {}).outcome || \"completed\") === \"completed\"",
        "trueLabel": "Completed",
        "falseLabel": "Cancelled or Abandoned"
      }
    },
    {
      "id": "terminateFlow",
      "type": "core.logic.terminate",
      "typeVersion": "1.0",
      "display": {
        "label": "Terminate Instance"
      },
